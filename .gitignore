# ============================================
# ROOT PROJECT GITIGNORE
# School Management System (Laravel + Next.js)
# ============================================

# ============================================
# DEPENDENCIES
# ============================================
/vendor/
/node_modules/
*.lock
yarn.lock
package-lock.json
composer.lock

# ============================================
# ENVIRONMENT VARIABLES (NEVER COMMIT SECRETS!)
# ============================================
.env
.env.local
.env.*.local
.env.backup
.env.production
.env.*.php
supabase_settings.txt

# ============================================
# BUILD & CACHE (Generated files)
# ============================================
