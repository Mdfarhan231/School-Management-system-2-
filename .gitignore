/frontend/.next/
/frontend/dist/
/frontend/out/
/frontend/.turbo/

# Backend cache
/backend/bootstrap/cache/
/backend/storage/cache/
/backend/storage/framework/
/backend/public/build/
/backend/public/hot/

# ============================================
# LOGS & TEMPORARY FILES
# ============================================
*.log
/storage/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================
# IDE & EDITOR SETTINGS (Optional - personal preference)
# ============================================
.idea/
.vscode/
.nova/
.fleet/
.zed/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ============================================
